generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  UserSession[]
  authSessions AuthSession[]

  jobPreference JobPreference?
  jobProfile    JobProfile?
  jobs          Job[]
  jobNotifications JobNotification[]
  jobConsents   JobConsent[]
  jobApplications JobApplication[]
  jobSearches   JobSearchHistory[]
  resume        Resume?
  resumeVersions ResumeVersion[]
  externalConnections UserExternalConnection[]
  externalJobApplications ExternalJobApplication[]
  jobMatches JobMatch[]
  integrationLogs IntegrationLog[]
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id              String   @id @default(cuid())
  userId          String?
  name            String?
  email           String?
  consentAccepted Boolean
  createdAt       DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers Answer[]
  result  Result?
}

model Question {
  id        String   @id @default(cuid())
  slug      String   @unique
  text      String
  category  String
  type      String   @default("scale")
  options   Json?
  tags      Json?
  active    Boolean  @default(true)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weights QuestionWeight[]
  answers Answer[]
}

model Profile {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  description           String
  strengths             Json
  attentionPoints       Json
  suggestedDegrees      Json
  suggestedShortCourses Json
  searchKeywords        Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  weights QuestionWeight[]
  courses CourseRecommendation[]
}

model QuestionWeight {
  id         String @id @default(cuid())
  questionId String
  profileId  String
  weight     Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([questionId, profileId])
}

model Answer {
  id         String   @id @default(cuid())
  sessionId  String
  questionId String
  value      Int
  createdAt  DateTime @default(now())

  session  UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
}

model Result {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  scores         Json
  topProfiles    Json
  capacityScores Json?
  createdAt      DateTime @default(now())

  session UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model CourseRecommendation {
  id          String   @id @default(cuid())
  profileSlug String
  title       String
  provider    String
  url         String
  type        String
  isFree      Boolean  @default(true)
  source      String
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile Profile @relation(fields: [profileSlug], references: [slug], onDelete: Cascade)
}

model CapacityTest {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  relatedProfiles Json
  studyTips   Json
  order       Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions CapacityQuestion[]
}

model CapacityQuestion {
  id            String @id @default(cuid())
  testId        String
  text          String
  options       Json
  correctAnswer String
  explanation   String
  order         Int

  test CapacityTest @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model AppLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  meta      Json?
  createdAt DateTime @default(now())
}

// ===== Área Vagas (nova) — não altera tabelas existentes =====

model JobPreference {
  id                 String   @id @default(cuid())
  userId             String   @unique
  cargo              String?
  area               String?
  cidade             String?
  estado             String?
  modelo             String   @default("qualquer")
  salarioMin         Float?
  salarioMax         Float?
  nivel              String   @default("qualquer")
  contrato           String   @default("qualquer")
  keywordsDesejadas  Json     @default("[]")
  keywordsEvitar     Json     @default("[]")
  aceitaSemSalario   Boolean  @default(true)
  aceitaForaCidade   Boolean  @default(true)
  frequenciaBusca    String   @default("manual")
  recebeNotificacoes Boolean  @default(true)
  ultimaBuscaEm      DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobs       Job[]
  searches   JobSearchHistory[]
  consents   JobConsent[]
  notifications JobNotification[]
}

model JobProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  resultId        String?
  topProfileNames Json     @default("[]")
  strengths       Json     @default("[]")
  keywords        Json     @default("[]")
  summary         String?
  phone           String?
  city            String?
  state           String?
  linkedin        String?
  country         String?
  countryCode     String?
  location        String?
  workAuthorization String?
  needsVisaSponsorship Boolean?
  citizenshipStatus String?
  englishLevel    String?
  currentSalary   String?
  currentEmployer String?
  currentRole     String?
  latestSchool    String?
  latestDegree    String?
  onsiteAvailability String?
  applicationSource String?
  pretensaoMin    Float?
  pretensaoMax    Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  consents  JobConsent[]
  applications JobApplication[]
}

model Job {
  id                 String   @id @default(cuid())
  userId             String
  title              String
  company            String?
  city               String?
  state              String?
  modelo             String?
  salario            String?
  contrato           String?
  nivel              String?
  description        String?
  requisitos         Json?
  beneficios         Json?
  originalUrl        String
  source             String
  sourceAutoSupport  String   @default("link_only")
  applyEmail         String?
  atsBoard           String?
  atsJobId           String?
  publishedAt        DateTime?
  foundAt            DateTime @default(now())
  status             String   @default("nova")
  confidence         Float    @default(0.5)
  dedupHash          String
  compatibilityScore Int      @default(0)
  compatibilityReason String?
  compatibilityBlock String?
  viewed             Boolean  @default(false)
  selected           Boolean  @default(false)
  notified           Boolean  @default(false)
  createdAt          DateTime @default(now())

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  preference   JobPreference?   @relation(fields: [preferenceId], references: [id], onDelete: SetNull)
  preferenceId String?
  applications JobApplication[]

  @@unique([userId, dedupHash])
  @@index([userId, status])
  @@index([userId, compatibilityScore])
}

model JobNotification {
  id         String   @id @default(cuid())
  userId     String
  message    String
  areaCargo  String?
  jobCount   Int      @default(0)
  searchDate DateTime @default(now())
  read       Boolean  @default(false)
  jobIds     Json     @default("[]")
  createdAt  DateTime @default(now())

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  preference JobPreference? @relation(fields: [preferenceId], references: [id], onDelete: SetNull)
  preferenceId String?

  @@index([userId, read])
}

model JobConsent {
  id           String   @id @default(cuid())
  userId       String
  consentedAt  DateTime @default(now())
  jobCount     Int
  resumeUsed   String?
  status       String   @default("confirmado")
  jobIds       Json     @default("[]")
  createdAt    DateTime @default(now())

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobProfile   JobProfile?    @relation(fields: [jobProfileId], references: [id], onDelete: SetNull)
  jobProfileId String?
  preference   JobPreference? @relation(fields: [preferenceId], references: [id], onDelete: SetNull)
  preferenceId String?
  applications JobApplication[]
}

model JobApplication {
  id              String   @id @default(cuid())
  userId          String
  jobId           String
  consentId       String?
  status          String   @default("aguardando")
  attemptedAt     DateTime?
  completedAt     DateTime?
  errorMessage    String?
  resumeSnapshot  Json?
  sourceCompat    String?
  createdAt       DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  consent   JobConsent?   @relation(fields: [consentId], references: [id], onDelete: SetNull)
  jobProfile JobProfile?  @relation(fields: [jobProfileId], references: [id], onDelete: SetNull)
  jobProfileId String?

  @@unique([userId, jobId])
  @@index([userId, status])
}

model JobSearchHistory {
  id         String   @id @default(cuid())
  userId     String
  searchedAt DateTime @default(now())
  source     String
  query      String?
  filters    Json?
  foundCount Int      @default(0)
  newCount   Int      @default(0)

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  preference JobPreference? @relation(fields: [preferenceId], references: [id], onDelete: SetNull)
  preferenceId String?

  @@index([userId, searchedAt])
}

// ===== Currículo persistente + upload (v1.3.0) =====

model Resume {
  id                String   @id @default(cuid())
  userId            String   @unique
  resultId          String?
  title             String   @default("Profissional")
  phone             String?
  linkedin          String?
  summary           String?
  photo             String?
  experiences       Json     @default("[]")
  education         Json     @default("[]")
  topProfileNames   Json     @default("[]")
  strengths         Json     @default("[]")
  uploadedFileName  String?
  uploadedFileData  Bytes?
  uploadedFileType  String?
  uploadedFileSize  Int?
  uploadedText      String?
  uploadedAt        DateTime?
  activeResumeType  String   @default("builder")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions ResumeVersion[]
}

model ResumeVersion {
  id                String   @id @default(cuid())
  userId            String
  resumeId          String?
  name              String
  kind              String   @default("visual")
  templateId        String
  targetArea        String?
  targetRole        String?
  visualConfig      Json     @default("{}")
  sectionConfig     Json     @default("{}")
  guideAnswers      Json     @default("{}")
  scores            Json     @default("{}")
  suggestions       Json     @default("[]")
  exportHistory     Json     @default("[]")
  isPrincipal       Boolean  @default(false)
  useForAutoApply   Boolean  @default(false)
  useForManualApply Boolean  @default(false)
  useForAreas       Json     @default("[]")
  driveFileId       String?
  driveFileUrl      String?
  driveExportUrl    String?
  targetExternalJob ExternalJob? @relation(fields: [targetExternalJobId], references: [id], onDelete: SetNull)
  targetExternalJobId String?
  matches JobMatch[]
  externalApplications ExternalJobApplication[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, isPrincipal])
  @@index([userId, useForAutoApply])
}

// ===== Boards ATS gerenciáveis via admin (v1.3.0) =====

model ATSBoard {
  id        String   @id @default(cuid())
  source    String
  boardKey  String
  label     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, boardKey])
}

// ===== Job Distribution & Profile Integration Layer (v1.7.0) =====

model IntegrationProvider {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  type                  String   @default("job_distribution")
  authType              String   @default("not_available")
  status                String   @default("pending_credentials")
  baseUrl               String?
  clientIdEncrypted     String?
  clientSecretEncrypted String?
  apiKeyEncrypted       String?
  webhookSecretEncrypted String?
  scopesJson            Json     @default("[]")
  capabilitiesJson      Json     @default("[]")
  settingsJson          Json     @default("{}")
  isVisibleToUsers      Boolean  @default(false)
  environment           String   @default("production")
  dailyLimit            Int      @default(0)
  monthlyLimit          Int      @default(0)
  lastHealthcheckAt     DateTime?
  lastHealthcheckStatus String?
  lastError             String?
  activeAt              DateTime?
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  connections          UserExternalConnection[]
  externalJobs         ExternalJob[]
  externalApplications ExternalJobApplication[]
  logs                 IntegrationLog[]
  rateLimits           IntegrationRateLimit[]

  @@index([status])
  @@index([isVisibleToUsers])
}

model UserExternalConnection {
  id                     String   @id @default(cuid())
  userId                 String
  providerId             String
  providerSlug           String
  externalAccountId      String?
  externalAccountName    String?
  externalEmail          String?
  connectionStatus       String   @default("pending")
  authType               String   @default("not_available")
  accessTokenEncrypted   String?
  refreshTokenEncrypted  String?
  tokenExpiresAt         DateTime?
  composioEntityId       String?
  composioConnectionId   String?
  scopesJson             Json     @default("[]")
  metadataJson           Json     @default("{}")
  lastSyncAt             DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider   IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
  @@index([userId, connectionStatus])
  @@index([providerSlug])
}

model ExternalJob {
  id              String   @id @default(cuid())
  providerId      String?
  providerSlug    String
  externalJobId   String?
  title           String
  companyName     String?
  location        String?
  remoteType      String?
  contractType    String?
  salaryMin       Float?
  salaryMax       Float?
  description     String?
  requirementsJson Json    @default("[]")
  benefitsJson     Json    @default("[]")
  applicationUrl  String?
  sourceUrl       String?
  metadataJson     Json    @default("{}")
  publishedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  provider    IntegrationProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  applications ExternalJobApplication[]
  matches      JobMatch[]
  resumeVersions ResumeVersion[]

  @@unique([providerSlug, externalJobId])
  @@index([providerSlug])
  @@index([title])
}

model JobMatch {
  id                            String   @id @default(cuid())
  userId                        String
  externalJobId                 String
  matchScore                    Int      @default(0)
  matchReason                   String?
  missingSkillsJson             Json     @default("[]")
  recommendedCoursesJson        Json     @default("[]")
  recommendedResumeVersionId    String?
  status                        String   @default("suggested")
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalJob   ExternalJob   @relation(fields: [externalJobId], references: [id], onDelete: Cascade)
  resumeVersion ResumeVersion? @relation(fields: [recommendedResumeVersionId], references: [id], onDelete: SetNull)

  @@unique([userId, externalJobId])
  @@index([userId, status])
  @@index([matchScore])
}

model ExternalJobApplication {
  id                  String   @id @default(cuid())
  userId              String
  externalJobId       String
  providerId          String?
  providerSlug        String
  resumeVersionId     String?
  applicationStatus   String   @default("pending_user_approval")
  applicationMode     String   @default("manual_assisted")
  externalApplicationId String?
  consentAccepted     Boolean  @default(false)
  submittedAt         DateTime?
  lastStatusSyncAt    DateTime?
  errorMessage        String?
  metadataJson        Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalJob     ExternalJob       @relation(fields: [externalJobId], references: [id], onDelete: Cascade)
  provider        IntegrationProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  resumeVersion   ResumeVersion?    @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)

  @@index([userId, applicationStatus])
  @@index([providerSlug])
}

model IntegrationLog {
  id                String   @id @default(cuid())
  userId            String?
  providerId        String?
  providerSlug      String
  action            String
  status            String
  requestSummaryJson Json    @default("{}")
  responseSummaryJson Json   @default("{}")
  errorMessage      String?
  createdAt         DateTime @default(now())

  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider  IntegrationProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([providerSlug, createdAt])
  @@index([status])
}

model IntegrationRateLimit {
  id             String   @id @default(cuid())
  providerSlug   String
  usedToday      Int      @default(0)
  usedThisMonth  Int      @default(0)
  resetAt        DateTime @default(now())
  monthResetAt   DateTime @default(now())
  updatedAt      DateTime @updatedAt

  provider IntegrationProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String

  @@unique([providerId])
}

